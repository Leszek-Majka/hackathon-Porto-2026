        </ids:property>
        <ids:property uri="https://identifier.buildingsmart.org/uri/buildingsmart/ifc/4.3/prop/GlobalTradeItemNumber" cardinality="optional" instructions="The Global Trade Item Number (GTIN) is an identifier for trade items developed by GS1 (www.gs1.org).">
