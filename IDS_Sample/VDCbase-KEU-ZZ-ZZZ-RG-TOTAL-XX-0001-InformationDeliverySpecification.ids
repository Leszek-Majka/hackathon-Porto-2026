<ids:ids xmlns:xs="http://www.w3.org/2001/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://standards.buildingsmart.org/IDS http://standards.buildingsmart.org/IDS/1.0/ids.xsd" xmlns:ids="http://standards.buildingsmart.org/IDS">
  <ids:info>
    <ids:title>18AB-OOG-ZZ-ZZZ-RG-ALG-XX-0001-InformationDeliverySpecification</ids:title>
    <ids:copyright>POHV</ids:copyright>
    <ids:version>1.1</ids:version>
    <ids:description>Basis voor in alle informatiemodellen</ids:description>
    <ids:author>lex@vdcbase.com</ids:author>
    <ids:date>2025-07-08</ids:date>
    <ids:purpose>ILS01 tot ILS26 </ids:purpose>
    <ids:milestone>alle fases – voorproject aanpak nog fase specifiek te maken</ids:milestone>
  </ids:info>
  <ids:specifications>
    <ids:specification ifcVersion="IFC4 IFC4X3_ADD2" name="Project" identifier="Project" description="Een informatiemodel moet de IFCClass IFCPROJECT bevatten zodat men de representationcontext heeft waar men t.o.v. IFCMAPCONVERSION de Local placement gedaan kan worden." instructions="https://www.researchgate.net/figure/The-full-geo-referencing-model-for-IFC_fig8_351907369 &#xA;The full geo-referencing model for IFC. | Download Scientific Diagram (researchgate.net)">
      <ids:applicability minOccurs="1" maxOccurs="unbounded">
        <ids:entity>
          <ids:name>
            <ids:simpleValue>IFCPROJECT</ids:simpleValue>
          </ids:name>
        </ids:entity>
      </ids:applicability>
      <ids:requirements>
        <ids:attribute cardinality="required" instructions="Naam&#xA;Voorbeeld: voortgezet onderwijs">
          <ids:name>
            <ids:simpleValue>Name</ids:simpleValue>
          </ids:name>
        </ids:attribute>
        <ids:attribute cardinality="optional" instructions="Toelichting&#xA;Voorbeeld: basisschool met kinderdagverblijf">
          <ids:name>
            <ids:simpleValue>Description</ids:simpleValue>
          </ids:name>
        </ids:attribute>
        <ids:attribute cardinality="required" instructions="Fase volgende STB2014 of 2025: Voorbeeld: 05 Definitief ontwerp">
          <ids:name>
            <ids:simpleValue>Phase</ids:simpleValue>
          </ids:name>
          <ids:value>
            <xs:restriction base="xs:string">
              <xs:enumeration value="01 Initiatief/haalbaarheid" />
              <xs:enumeration value="02 Projectdefinitie" />
              <xs:enumeration value="03 Structuurontwerp" />
              <xs:enumeration value="04 Voorontwerp" />
              <xs:enumeration value="05 Definitief ontwerp" />
              <xs:enumeration value="06 Technisch ontwerp/Bestek" />
              <xs:enumeration value="07 Prijs- en Contractvorming" />
              <xs:enumeration value="08 Uitvoering - Uitvoeringsgereed Ontwerp" />
              <xs:enumeration value="09 Uitvoering - Directievoering" />
              <xs:enumeration value="10 Gebruik/Exploitatie" />
              <xs:enumeration value="1.1 Initiatief" />
              <xs:enumeration value="1.2 Haalbaarheid" />
              <xs:enumeration value="1.3 Projectdefinitie" />
              <xs:enumeration value="2.1 Structuurontwerp" />
              <xs:enumeration value="2.2 Voorontwerp" />
              <xs:enumeration value="2.3 Definitief Ontwerp" />
              <xs:enumeration value="2.4 Omgevingsvergunning aanvraag" />
              <xs:enumeration value="3.1 Technisch ontwerp" />
              <xs:enumeration value="3.2 Uitvoering gereed ontwerp" />
              <xs:enumeration value="4.1 Uitvoering" />
              <xs:enumeration value="4.2 Overdracht en oplevering" />
              <xs:enumeration value="4.3 Onderhoudstermijn" />
              <xs:enumeration value="5 Gebruik en Exploitatie" />
            </xs:restriction>
          </ids:value>
        </ids:attribute>
        <ids:attribute cardinality="required" instructions="Eenheden&#xA;voorbeeld: m of mm (gebouwen zijn gebruikelijk in mm en de georeferentie in m) er zijn er dus 2 in IFC files.)">
          <ids:name>
            <ids:simpleValue>UnitsInContext</ids:simpleValue>
          </ids:name>
        </ids:attribute>
        <ids:property dataType="IFCLABEL" uri="https://identifier.buildingsmart.org/uri/buildingsmart/ifc/4.3/prop/ProjectType" cardinality="required">
          <ids:propertySet>
            <ids:simpleValue>Pset_ProjectCommon</ids:simpleValue>
          </ids:propertySet>
          <ids:baseName>
            <ids:simpleValue>ProjectType</ids:simpleValue>
          </ids:baseName>
          <ids:value>
            <xs:restriction base="xs:string">
              <xs:enumeration value="MODIFICATION" />
              <xs:enumeration value="NEWBUILD" />
              <xs:enumeration value="OPERATIONMAINTENANCE" />
              <xs:enumeration value="RENOVATION" />
              <xs:enumeration value="REPAIR" />
            </xs:restriction>
          </ids:value>
        </ids:property>
        <ids:property dataType="IFCLABEL" uri="https://identifier.buildingsmart.org/uri/buildingsmart/ifc/4.3/prop/ProjectInvestmentEstimate" cardinality="optional" instructions="Stichtingskosten: NEN2699 Niveau 1 : A t/m G&#xA;Voorbeeld: 1000000">
          <ids:propertySet>
            <ids:simpleValue>Pset_ProjectCommon</ids:simpleValue>
          </ids:propertySet>
          <ids:baseName>
            <ids:simpleValue>ProjectInvestmentEstimate</ids:simpleValue>
          </ids:baseName>
        </ids:property>
      </ids:requirements>
    </ids:specification>
    <ids:specification ifcVersion="IFC4 IFC4X3_ADD2" name="GeoreferentieProjectedCRS" identifier="GeoreferentieProjectedCRS" description="Een informatiemodel moet de IFCClass IFCPROJECTEDCRS met attribuut VerticalDatum EPSG:7415 (RD+NAP)of EPSG:28992 (RD) én EPSG:5709 (NAP)" instructions="Deze CRS-eis geldt alleen voor Nederlandse projecten waarbij de omvang van het project i.c.m. de kromming van de aarde geen probleem oplevert. Als dit niet geldt dan is het ook mogelijk om eventueel IfcGeographicCRS en/of andere EPSG te gebruiken.">
      <ids:applicability minOccurs="1" maxOccurs="unbounded">
        <ids:entity>
          <ids:name>
            <ids:simpleValue>IFCPROJECTEDCRS</ids:simpleValue>
          </ids:name>
        </ids:entity>
        <ids:attribute>
          <ids:name>
            <ids:simpleValue>Name</ids:simpleValue>
          </ids:name>
          <ids:value>
            <xs:restriction base="xs:string">
              <xs:enumeration value="EPSG:7415" />
              <xs:enumeration value="EPSG:28992" />
            </xs:restriction>
          </ids:value>
        </ids:attribute>
      </ids:applicability>
      <ids:requirements>
        <ids:attribute cardinality="required" instructions="Doel coördinatenstelsel waarin het BIM-model geplaatst wordt. EPSG 7415&#xA;Het attribuut TargetCRS voor Nederlandse indiening heeft als verplichte waarde een IfcProjectedCRS met attribuut VerticalDatum EPSG:7415 (RD+NAP)of EPSG:28992 (RD) én EPSG:5709 (NAP)&#xA;https://www.opengis.net/def/crs/EPSG/0/28992">
          <ids:name>
            <ids:simpleValue>Name</ids:simpleValue>
          </ids:name>
          <ids:value>
            <xs:restriction base="xs:string">
              <xs:enumeration value="EPSG:7415" />
              <xs:enumeration value="EPSG:28992" />
            </xs:restriction>
          </ids:value>
        </ids:attribute>
      </ids:requirements>
    </ids:specification>
    <ids:specification ifcVersion="IFC4 IFC4X3_ADD2" name="GeoreferentieMapConversion" identifier="GeoreferentieMapConversion" description="Een informatiemodel moet de IFCClass IFCMAPCONVERSION bevatten met de attributen SourceCRS, TargetCRS, Easting, Northing, OrthogonalHeight, XAxisAbscissa, XAxisOrdinate en Scale ingevuld." instructions="Deze CRS-eis geldtDeze CRS-eis geldt alleen voor Nederlandse projecten waarbij de omvang van het project i.c.m. de kromming van de aarde geen probleem oplevert. Als dit niet geldt dan is het ook mogelijk om eventueel IfcGeographicCRS en/of andere EPSG te gebruiken.">
      <ids:applicability minOccurs="1" maxOccurs="unbounded">
        <ids:entity>
          <ids:name>
            <ids:simpleValue>IFCMAPCONVERSION</ids:simpleValue>
          </ids:name>
        </ids:entity>
      </ids:applicability>
      <ids:requirements>
        <ids:attribute cardinality="required" instructions="Verplaatsing in Oostrichting om het BIM-model op de goede plek te krijgen.&#xA;Voorbeeld: 92370.710706">
          <ids:name>
            <ids:simpleValue>Eastings</ids:simpleValue>
          </ids:name>
        </ids:attribute>
        <ids:attribute cardinality="required" instructions="Verplaatsing in Noordrichting om het BIM-model op de goede plek te krijgen.&#xA;Voorbeeld: 437455.379788">
          <ids:name>
            <ids:simpleValue>Northings</ids:simpleValue>
          </ids:name>
        </ids:attribute>
        <ids:attribute cardinality="required" instructions="Verplaatsing in Hoogterichting om het BIM-model op de goede plek te krijgen.&#xA;Voorbeeld: 1.3092">
          <ids:name>
            <ids:simpleValue>OrthogonalHeight</ids:simpleValue>
          </ids:name>
        </ids:attribute>
        <ids:attribute cardinality="required" instructions="Specificeert de waarde langs de oostelijke as van het eindpunt van een vector die de positie van de lokale x-as van het engineering coördinaatreferentiesysteem aangeeft.&#xA;Voorbeeld: 0.8">
          <ids:name>
            <ids:simpleValue>XAxisAbscissa</ids:simpleValue>
          </ids:name>
        </ids:attribute>
        <ids:attribute cardinality="required" instructions="Specificeert de waarde langs de oostelijke as van het eindpunt van een vector die de positie van de lokale x-as van het engineering coördinaatreferentiesysteem aangeeft.&#xA;Voorbeeld: 0.1">
          <ids:name>
            <ids:simpleValue>XAxisOrdinate</ids:simpleValue>
          </ids:name>
        </ids:attribute>
        <ids:attribute cardinality="optional" instructions="Schaal van eenheden in BIM-model t.o.v. eenheden in target CRS&#xA;Voorbeeld: 1/0.001">
          <ids:name>
            <ids:simpleValue>Scale</ids:simpleValue>
          </ids:name>
        </ids:attribute>
      </ids:requirements>
    </ids:specification>
    <ids:specification ifcVersion="IFC4 IFC4X3_ADD2" name="Site" identifier="Site">
      <ids:applicability minOccurs="1" maxOccurs="unbounded">
        <ids:entity>
          <ids:name>
            <ids:simpleValue>IFCSITE</ids:simpleValue>
          </ids:name>
        </ids:entity>
      </ids:applicability>
      <ids:requirements>
        <ids:attribute cardinality="required">
          <ids:name>
            <ids:simpleValue>Name</ids:simpleValue>
          </ids:name>
        </ids:attribute>
        <ids:property dataType="IFCBOOLEAN" uri="https://identifier.buildingsmart.org/uri/buildingsmart/ifc/4.3/prop/IsPermanentID" cardinality="required">
          <ids:propertySet>
            <ids:simpleValue>Pset_LandRegistration</ids:simpleValue>
          </ids:propertySet>
          <ids:baseName>
            <ids:simpleValue>IsPermanentID</ids:simpleValue>
          </ids:baseName>
          <ids:value>
            <ids:simpleValue>true</ids:simpleValue>
          </ids:value>
        </ids:property>
        <ids:property dataType="IFCIDENTIFIER" uri="https://identifier.buildingsmart.org/uri/buildingsmart/ifc/4.3/prop/LandID" cardinality="required" instructions="identificatieLokaalID uit Pset_LandRegistration&#xA;voorbeeld: 19650000670000">
          <ids:propertySet>
            <ids:simpleValue>Pset_LandRegistration</ids:simpleValue>
          </ids:propertySet>
          <ids:baseName>
            <ids:simpleValue>LandID</ids:simpleValue>
          </ids:baseName>
        </ids:property>
        <ids:property dataType="IFCIDENTIFIER" uri="https://identifier.buildingsmart.org/uri/buildingsmart/ifc/4.3/prop/LandTitleID" cardinality="optional">
          <ids:propertySet>
            <ids:simpleValue>Pset_LandRegistration</ids:simpleValue>
          </ids:propertySet>
          <ids:baseName>
            <ids:simpleValue>LandTitleID</ids:simpleValue>
          </ids:baseName>
        </ids:property>
      </ids:requirements>
    </ids:specification>
    <ids:specification ifcVersion="IFC4 IFC4X3_ADD2" name="Bouwwerkperceel" identifier="Bouwwerkperceel" description="Een informatiemodel voor nieuwbouw moet minimaal 1 IFCClass IFCSPATIALZONE met het ObjectType Bouwwerkperceel (iplo).&#xA;Deze bevat verplicht de attributen: Description, Objecttype, Objectplacement, Representation.&#xA;Wanneer een Informatiemodel meerdere bouwwerk- of kadastraalpercelen bevat dient de relatie IfcRelReferencedInSpatialStructure aan te geven welk perceel in een ander perceel zit.">
      <ids:applicability minOccurs="0" maxOccurs="unbounded">
        <ids:attribute>
          <ids:name>
            <ids:simpleValue>ObjectType</ids:simpleValue>
          </ids:name>
          <ids:value>
            <ids:simpleValue>Bouwwerkperceel</ids:simpleValue>
          </ids:value>
        </ids:attribute>
      </ids:applicability>
      <ids:requirements>
        <ids:entity>
          <ids:name>
            <xs:restriction base="xs:string">
              <xs:enumeration value="IFCSPATIALZONE" />
              <xs:enumeration value="IFCSPACE" />
            </xs:restriction>
          </ids:name>
        </ids:entity>
        <ids:attribute cardinality="required" instructions="Bepalingsmethode&#xA;voorbeeld: Terreinvolume">
          <ids:name>
            <ids:simpleValue>Description</ids:simpleValue>
          </ids:name>
          <ids:value>
            <xs:restriction base="xs:string">
              <xs:enumeration value="Terreinvolume" />
              <xs:enumeration value="Onbebouwd Terreinvolume" />
              <xs:enumeration value="Overbouwd Terreinvolume" />
              <xs:enumeration value="Onderbouwd Terreinvolume" />
              <xs:enumeration value="Bebouwd Terreinvolume" />
              <xs:enumeration value="Netto Inhoud" />
              <xs:enumeration value="Bruto Inhoud" />
              <xs:enumeration value="Tarra Inhoud" />
              <xs:enumeration value="GebruiksInhoud" />
              <xs:enumeration value="Verhuurbare Inhoud" />
              <xs:enumeration value="Nuttige Inhoud" />
              <xs:enumeration value="Functioneel Nuttige Inhoud" />
              <xs:enumeration value="Programma van Eisen Inhoud" />
            </xs:restriction>
          </ids:value>
        </ids:attribute>
        <ids:attribute cardinality="required" instructions="Beschrijving van het soort buitenruimte&#xA;Voorbeeld: Bouwwerkperceel">
          <ids:name>
            <ids:simpleValue>ObjectType</ids:simpleValue>
          </ids:name>
          <ids:value>
            <ids:simpleValue>Bouwwerkperceel</ids:simpleValue>
          </ids:value>
        </ids:attribute>
        <ids:attribute cardinality="required" instructions="De plaatsing van het bouwwerkperceel&#xA;Voorbeeld: IfcObjectPlacement">
          <ids:name>
            <ids:simpleValue>ObjectPlacement</ids:simpleValue>
          </ids:name>
        </ids:attribute>
        <ids:attribute cardinality="required" instructions="De vorm van het bouwwerkperceel&#xA;Voorbeeld: IfcProductRepresentation">
          <ids:name>
            <ids:simpleValue>Representation</ids:simpleValue>
          </ids:name>
        </ids:attribute>
        <ids:attribute cardinality="required" instructions="Unieke naam voor het bouwwerkperceel in communicatie&#xA;Woningbouwprojectperceel x">
          <ids:name>
            <ids:simpleValue>Name</ids:simpleValue>
          </ids:name>
        </ids:attribute>
        <ids:attribute cardinality="optional" instructions="De vrij te kiezen eigen naam van het bouwwerkperceel">
          <ids:name>
            <ids:simpleValue>LongName</ids:simpleValue>
          </ids:name>
        </ids:attribute>
      </ids:requirements>
    </ids:specification>
    <ids:specification ifcVersion="IFC4 IFC4X3_ADD2" name="Kadastraal perceel" identifier="Kadastraal perceel" description="Een informatiemodel moet minimaal 1 IFCClass IFCSPATIALZONE met het ObjectType Kadastraal perceel (iplo)." instructions="Wanneer en Informatiemodel een kadastraalperceel bevat gelden bovenop ook de verplichte properties IfcLandID en IfcIsPermanentID. De properties IfcLandID en IfcIsPermanentID zijn alleen voor IfcSite beschikbaar. Deze kunnen als propertyset aangemaakt worden voor deze IfcSpatialZone.">
      <ids:applicability minOccurs="0" maxOccurs="unbounded">
        <ids:attribute>
          <ids:name>
            <ids:simpleValue>ObjectType</ids:simpleValue>
          </ids:name>
          <ids:value>
            <ids:simpleValue>Kadastraal perceel</ids:simpleValue>
          </ids:value>
        </ids:attribute>
      </ids:applicability>
      <ids:requirements>
        <ids:entity>
          <ids:name>
            <xs:restriction base="xs:string">
              <xs:enumeration value="IFCSPATIALZONE" />
              <xs:enumeration value="IFCSPACE" />
            </xs:restriction>
          </ids:name>
        </ids:entity>
        <ids:partOf relation="IFCRELCONTAINEDINSPATIALSTRUCTURE" cardinality="required" instructions="Gebouwen of percelen binnen het kadastraal perceel">
          <ids:entity>
            <ids:name>
              <xs:restriction base="xs:string">
                <xs:enumeration value="IFCBUILDING" />
                <xs:enumeration value="IFCPROJECT" />
              </xs:restriction>
            </ids:name>
          </ids:entity>
        </ids:partOf>
        <ids:attribute cardinality="required" instructions="Name&#xA;Optioneel Naam&#xA;Woningbouwproject x">
          <ids:name>
            <ids:simpleValue>Name</ids:simpleValue>
          </ids:name>
        </ids:attribute>
        <ids:attribute cardinality="required" instructions="Bepalingsmethode tablel 9.19.1 Terreinvolume, Onbebouwd Terreinvolume, Overbouwd Terreinvolume, Onderbouwd Terreinvolume, Bebouwd Terreinvolume, Bruto Inhoud, Netto Inhoud, Tarra Inhoud, GebruiksInhoud, Verhuurbare Inhoud, Nuttige Inhoud, Functioneel Nuttige Inhoud, Programma van Eisen Inhoud,">
          <ids:name>
            <ids:simpleValue>Description</ids:simpleValue>
          </ids:name>
          <ids:value>
            <xs:restriction base="xs:string">
              <xs:enumeration value="Terreinvolume" />
              <xs:enumeration value="Onbebouwd Terreinvolume" />
              <xs:enumeration value="Overbouwd Terreinvolume" />
              <xs:enumeration value="Onderbouwd Terreinvolume" />
              <xs:enumeration value="Bebouwd Terreinvolume" />
              <xs:enumeration value="Netto Inhoud" />
              <xs:enumeration value="Bruto Inhoud" />
              <xs:enumeration value="Tarra Inhoud" />
              <xs:enumeration value="GebruiksInhoud" />
              <xs:enumeration value="Verhuurbare Inhoud" />
              <xs:enumeration value="Nuttige Inhoud" />
              <xs:enumeration value="Functioneel Nuttige Inhoud" />
              <xs:enumeration value="Programma van Eisen Inhoud" />
            </xs:restriction>
          </ids:value>
        </ids:attribute>
        <ids:attribute cardinality="required" instructions="De plaatsing van het Kadastraal perceel">
          <ids:name>
            <ids:simpleValue>ObjectPlacement</ids:simpleValue>
          </ids:name>
        </ids:attribute>
        <ids:attribute cardinality="required" instructions="Representation&#xA;Verplicht De vorm van het Kadastraal perceel&#xA;IfcProductRepresentation">
          <ids:name>
            <ids:simpleValue>Representation</ids:simpleValue>
          </ids:name>
        </ids:attribute>
        <ids:attribute cardinality="optional">
          <ids:name>
            <ids:simpleValue>LongName</ids:simpleValue>
          </ids:name>
        </ids:attribute>
        <ids:property dataType="IFCBOOLEAN" uri="https://identifier.buildingsmart.org/uri/buildingsmart/ifc/4.3/prop/IsPermanentID" cardinality="required">
          <ids:propertySet>
            <ids:simpleValue>Pset_LandRegistration</ids:simpleValue>
          </ids:propertySet>
          <ids:baseName>
            <ids:simpleValue>IsPermanentID</ids:simpleValue>
          </ids:baseName>
          <ids:value>
            <ids:simpleValue>true</ids:simpleValue>
          </ids:value>
        </ids:property>
        <ids:property dataType="IFCIDENTIFIER" uri="https://identifier.buildingsmart.org/uri/buildingsmart/ifc/4.3/prop/LandID" cardinality="required" instructions="identificatieLokaalID uit Pset_LandRegistration&#xA;voorbeeld: 19650000670000">
          <ids:propertySet>
            <ids:simpleValue>Pset_LandRegistration</ids:simpleValue>
          </ids:propertySet>
          <ids:baseName>
            <ids:simpleValue>LandID</ids:simpleValue>
          </ids:baseName>
        </ids:property>
        <ids:property dataType="IFCLABEL" uri="https://identifier.buildingsmart.org/uri/buildingsmart/ifc/4.3/prop/LandTitleID" cardinality="optional">
          <ids:propertySet>
            <ids:simpleValue>Pset_LandRegistration</ids:simpleValue>
          </ids:propertySet>
          <ids:baseName>
            <ids:simpleValue>LandTitleID</ids:simpleValue>
          </ids:baseName>
        </ids:property>
      </ids:requirements>
    </ids:specification>
    <ids:specification ifcVersion="IFC4 IFC4X3_ADD2" name="Gebouw" identifier="Gebouw" instructions="Een Informatimodel voor een gebouw dient minimaal 1 IFCClass IFCBuilding te bevatten met de attributen: Description, Objecttype, Objectplacement. En de properties: BuildingID, IsPermanentID, MarketCategory en MarketSubCategory. Er kunnen meerdere gebouwen zijn in één project met een andere market (sub)category. Bij meerdere IFC’s is dit mogelijk. Een gebouw, bestaande uit twee woontoren en een parkeergarage zijn dus drie losse ifc-files met een BuildingID aan elkaar gelinkt.">
      <ids:applicability minOccurs="1" maxOccurs="unbounded">
        <ids:entity>
          <ids:name>
            <ids:simpleValue>IFCBUILDING</ids:simpleValue>
          </ids:name>
        </ids:entity>
      </ids:applicability>
      <ids:requirements>
        <ids:attribute cardinality="required">
          <ids:name>
            <ids:simpleValue>Name</ids:simpleValue>
          </ids:name>
        </ids:attribute>
        <ids:attribute cardinality="optional" instructions="Beschrijving van het soort IfcBuilding&#xA;Voorbeeld: Onderwijsgebouw, Kinderdagveblijf, IKC, Pand, Rijwoning, Appartement">
          <ids:name>
            <ids:simpleValue>ObjectType</ids:simpleValue>
          </ids:name>
        </ids:attribute>
        <ids:attribute cardinality="optional">
          <ids:name>
            <ids:simpleValue>LongName</ids:simpleValue>
          </ids:name>
        </ids:attribute>
        <ids:attribute cardinality="optional" instructions="Adres van het gebouw, wordt niet gebruik voor georeferentie, puur ter info">
          <ids:name>
            <ids:simpleValue>SiteAddress</ids:simpleValue>
          </ids:name>
        </ids:attribute>
        <ids:property dataType="IFCIDENTIFIER" uri="https://identifier.buildingsmart.org/uri/buildingsmart/ifc/4.3/prop/BuildingID" cardinality="required" instructions="Gebouw-werk-ID of BAG-Pand-ID wanneer beschikbaar (Uit pset_buildingCommon) &#xA;voorbeeld: 003100000122684&#xA;Als dit een BAGPAND ID is dan staat de  IsPermanentID op True, zo niet  dan False en nummeren met 000000000">
          <ids:propertySet>
            <ids:simpleValue>Pset_BuildingCommon</ids:simpleValue>
          </ids:propertySet>
          <ids:baseName>
            <ids:simpleValue>BuildingID</ids:simpleValue>
          </ids:baseName>
        </ids:property>
        <ids:property dataType="IFCBOOLEAN" uri="https://identifier.buildingsmart.org/uri/buildingsmart/ifc/4.3/prop/IsPermanentID" cardinality="required" instructions="Als Building ID het BAGPAND ID is, dan staat de IsPermanentID op True, zo niet dan False">
          <ids:propertySet>
            <ids:simpleValue>Pset_BuildingCommon</ids:simpleValue>
          </ids:propertySet>
          <ids:baseName>
            <ids:simpleValue>IsPermanentID</ids:simpleValue>
          </ids:baseName>
        </ids:property>
        <ids:property dataType="IFCLABEL" uri="https://identifier.buildingsmart.org/uri/buildingsmart/ifc/4.3/prop/MarketCategory" cardinality="optional" instructions="Duiding van soort gebouw zie enumeratie (gebouwtype) &gt; zie ennummeratie gebouwtype&#xA;Voorbeeld: Woongebouw&#xA;Bron: Geonovum.github.io/disgeo Inhoud-2/#-gebouw&#xA;Kantoor op basis van: kantorengebouwn-in-nl-1945-2015">
          <ids:propertySet>
            <ids:simpleValue>Pset_BuildingUse</ids:simpleValue>
          </ids:propertySet>
          <ids:baseName>
            <ids:simpleValue>MarketCategory</ids:simpleValue>
          </ids:baseName>
          <ids:value>
