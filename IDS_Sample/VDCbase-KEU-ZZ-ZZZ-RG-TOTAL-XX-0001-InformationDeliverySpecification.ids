        <ids:property dataType="IFCREAL" uri="https://identifier.buildingsmart.org/uri/TUe/DOR/0.0.2/prop/EconomicLife" cardinality="optional" instructions="Economic Life refers to the amount of time an element is in service before it is more economically advantageous to decommission or replace it. The Economic Life can be used in cases where the exact service life or design life is not known, or if it does not match the expected service life of an existing building. The Economic Life is defined in years.">
          <ids:propertySet>
            <ids:simpleValue>CircularRequirement</ids:simpleValue>
          </ids:propertySet>
          <ids:baseName>
            <ids:simpleValue>EconomicLife</ids:simpleValue>
          </ids:baseName>
          <ids:value>
            <xs:restriction base="xs:integer">
              <xs:minExclusive value="0" />
              <xs:maxExclusive value="10000" />
            </xs:restriction>
          </ids:value>
        </ids:property>
        <ids:property dataType="IFCREAL" uri="https://identifier.buildingsmart.org/uri/TUe/DOR/0.0.2/prop/HazardousMaterial" cardinality="optional" instructions="According to the Waste Directive 2008/98/EC, hazardous materials are sourced from the type of resources that will cause health damage to humans, animals, plants, living organisms, and the environment. (Guidance on the classification and assessment of waste (1st Edition v1.2.GB) Technical Guidance WM3)">
          <ids:propertySet>
            <ids:simpleValue>CircularRequirement</ids:simpleValue>
          </ids:propertySet>
          <ids:baseName>
            <ids:simpleValue>HazardousMaterial</ids:simpleValue>
          </ids:baseName>
          <ids:value>
            <xs:restriction base="xs:string">
              <xs:enumeration value="HP1 Explosive" />
              <xs:enumeration value="HP2 Oxidizing" />
              <xs:enumeration value="HP3 Flammable" />
              <xs:enumeration value="HP4 Irritant" />
              <xs:enumeration value="HP5 Specific Target Organ Toxicity/Aspiration Toxicity" />
              <xs:enumeration value="HP6 Acute Toxicity" />
              <xs:enumeration value="HP7 Carcinogenic" />
              <xs:enumeration value="HP8 Corrosive" />
              <xs:enumeration value="HP9 Infectious" />
              <xs:enumeration value="HP10 Toxic for reproduction" />
            </xs:restriction>
          </ids:value>
        </ids:property>
        <ids:property dataType="IFCREAL" uri="https://identifier.buildingsmart.org/uri/TUe/DOR/0.0.2/prop/InterventionRequirement" cardinality="optional" instructions="Intervention Requirement is suggested for cases where a circular potential could be realised only after certain interventions are done. An intervention could be a minor or major modification after deconstruction, or an intervention during the life cycle. Similarly, this class can contain additional information when an intervention is of type of repair or replacement and so on.">
          <ids:propertySet>
            <ids:simpleValue>CircularRequirement</ids:simpleValue>
          </ids:propertySet>
          <ids:baseName>
            <ids:simpleValue>InterventionRequirement</ids:simpleValue>
          </ids:baseName>
        </ids:property>
        <ids:property uri="https://identifier.buildingsmart.org/uri/buildingsmart/ifc/4.3/prop/Manufacturer" cardinality="optional" instructions="The organization that manufactured and/or assembled the item.">
          <ids:propertySet>
            <ids:simpleValue>Pset_ManufacturerTypeInformation</ids:simpleValue>
          </ids:propertySet>
          <ids:baseName>
            <ids:simpleValue>Manufacturer</ids:simpleValue>
          </ids:baseName>
        </ids:property>
        <ids:property uri="https://identifier.buildingsmart.org/uri/buildingsmart/ifc/4.3/prop/GlobalTradeItemNumber" cardinality="optional" instructions="The Global Trade Item Number (GTIN) is an identifier for trade items developed by GS1 (www.gs1.org).">
          <ids:propertySet>
            <ids:simpleValue>Pset_ManufacturerTypeInformation</ids:simpleValue>
          </ids:propertySet>
          <ids:baseName>
            <ids:simpleValue>GlobalTradeItemNumber</ids:simpleValue>
          </ids:baseName>
        </ids:property>
        <ids:property uri="https://identifier.buildingsmart.org/uri/buildingsmart/ifc/4.3/prop/OperationalDocument" cardinality="optional" instructions="Manufacturer's operationeel document">
          <ids:propertySet>
            <ids:simpleValue>Pset_ManufacturerTypeInformation</ids:simpleValue>
          </ids:propertySet>
          <ids:baseName>
            <ids:simpleValue>OperationalDocument</ids:simpleValue>
          </ids:baseName>
        </ids:property>
        <ids:property uri="https://identifier.buildingsmart.org/uri/buildingsmart/ifc/4.3/prop/PerformanceCertificate" cardinality="optional" instructions="Manufacturer's prestatiecertificaat ">
          <ids:propertySet>
            <ids:simpleValue>Pset_ManufacturerTypeInformation</ids:simpleValue>
          </ids:propertySet>
          <ids:baseName>
            <ids:simpleValue>PerformanceCertificate</ids:simpleValue>
          </ids:baseName>
        </ids:property>
        <ids:property uri="https://identifier.buildingsmart.org/uri/buildingsmart/ifc/4.3/prop/SafetyDocument" cardinality="optional" instructions="Manufacturer's veiligheidsdocument">
          <ids:propertySet>
            <ids:simpleValue>Pset_ManufacturerTypeInformation</ids:simpleValue>
          </ids:propertySet>
          <ids:baseName>
            <ids:simpleValue>SafetyDocument</ids:simpleValue>
          </ids:baseName>
        </ids:property>
        <ids:property uri="https://identifier.buildingsmart.org/uri/buildingsmart/ifc/4.3/prop/AssessmentCondition" cardinality="optional" instructions="The overall condition of a product based on an assessment of the contributions to the overall condition made by the various criteria considered. The meanings given to the values of assessed condition should be agreed and documented by local agreements. For instance, is overall condition measured on a scale of 1 - 10 or by assigning names such as Good, OK, Poor.">
          <ids:propertySet>
            <ids:simpleValue>Pset_Condition</ids:simpleValue>
          </ids:propertySet>
          <ids:baseName>
            <ids:simpleValue>AssessmentCondition</ids:simpleValue>
          </ids:baseName>
        </ids:property>
        <ids:property dataType="IFCDATE" uri="https://identifier.buildingsmart.org/uri/buildingsmart/ifc/4.3/prop/AssessmentDate" cardinality="optional" instructions="Date on which the overall condition is assessed">
          <ids:propertySet>
            <ids:simpleValue>Pset_Condition</ids:simpleValue>
          </ids:propertySet>
          <ids:baseName>
            <ids:simpleValue>AssessmentDate</ids:simpleValue>
          </ids:baseName>
          <ids:value>
            <xs:restriction base="xs:date">
              <xs:minExclusive value="2000-01-01" />
            </xs:restriction>
          </ids:value>
        </ids:property>
        <ids:property uri="https://identifier.buildingsmart.org/uri/buildingsmart/ifc/4.3/prop/AssessmentDescription" cardinality="optional" instructions="Qualitative description of the condition.">
          <ids:propertySet>
            <ids:simpleValue>Pset_Condition</ids:simpleValue>
          </ids:propertySet>
          <ids:baseName>
            <ids:simpleValue>AssessmentDescription</ids:simpleValue>
          </ids:baseName>
        </ids:property>
        <ids:property uri="https://identifier.buildingsmart.org/uri/buildingsmart/ifc/4.3/prop/AssessmentType" cardinality="optional" instructions="Category of latest condition assessment report of the asset.">
          <ids:propertySet>
            <ids:simpleValue>Pset_Condition</ids:simpleValue>
          </ids:propertySet>
          <ids:baseName>
            <ids:simpleValue>AssessmentType</ids:simpleValue>
          </ids:baseName>
        </ids:property>
        <ids:property uri="https://identifier.buildingsmart.org/uri/buildingsmart/ifc/4.3/prop/AssessmentMethod" cardinality="optional" instructions="External reference to assessment method or application used to perform the assessment.">
          <ids:propertySet>
            <ids:simpleValue>Pset_Condition</ids:simpleValue>
          </ids:propertySet>
          <ids:baseName>
            <ids:simpleValue>AssessmentMethod</ids:simpleValue>
          </ids:baseName>
        </ids:property>
        <ids:material cardinality="required" />
      </ids:requirements>
    </ids:specification>
    <ids:specification ifcVersion="IFC4 IFC4X3_ADD2" name="Project" identifier="*Project" description="Een informatiemodel moet de IFCClass IFCPROJECT bevatten zodat men de representationcontext heeft waar men t.o.v. IFCMAPCONVERSION de Local placement gedaan kan worden." instructions="https://www.researchgate.net/figure/The-full-geo-referencing-model-for-IFC_fig8_351907369 &#xA;The full geo-referencing model for IFC. | Download Scientific Diagram (researchgate.net)">
      <ids:applicability minOccurs="1" maxOccurs="unbounded">
        <ids:entity>
          <ids:name>
            <ids:simpleValue>IFCPROJECT</ids:simpleValue>
          </ids:name>
        </ids:entity>
      </ids:applicability>
      <ids:requirements>
        <ids:attribute cardinality="required" instructions="Naam&#xA;Voorbeeld: voortgezet onderwijs">
          <ids:name>
            <ids:simpleValue>Name</ids:simpleValue>
          </ids:name>
        </ids:attribute>
        <ids:attribute cardinality="optional" instructions="Toelichting&#xA;Voorbeeld: basisschool met kinderdagverblijf">
          <ids:name>
            <ids:simpleValue>Description</ids:simpleValue>
          </ids:name>
        </ids:attribute>
        <ids:attribute cardinality="required" instructions="Fase volgende STB2014 of 2025: Voorbeeld: 05 Definitief ontwerp">
          <ids:name>
            <ids:simpleValue>Phase</ids:simpleValue>
          </ids:name>
          <ids:value>
            <xs:restriction base="xs:string">
              <xs:enumeration value="01 Initiatief/haalbaarheid" />
              <xs:enumeration value="02 Projectdefinitie" />
              <xs:enumeration value="03 Structuurontwerp" />
              <xs:enumeration value="04 Voorontwerp" />
              <xs:enumeration value="05 Definitief ontwerp" />
              <xs:enumeration value="06 Technisch ontwerp/Bestek" />
              <xs:enumeration value="07 Prijs- en Contractvorming" />
              <xs:enumeration value="08 Uitvoering - Uitvoeringsgereed Ontwerp" />
              <xs:enumeration value="09 Uitvoering - Directievoering" />
              <xs:enumeration value="10 Gebruik/Exploitatie" />
              <xs:enumeration value="1.1 Initiatief" />
              <xs:enumeration value="1.2 Haalbaarheid" />
              <xs:enumeration value="1.3 Projectdefinitie" />
              <xs:enumeration value="2.1 Structuurontwerp" />
              <xs:enumeration value="2.2 Voorontwerp" />
              <xs:enumeration value="2.3 Definitief Ontwerp" />
              <xs:enumeration value="2.4 Omgevingsvergunning aanvraag" />
              <xs:enumeration value="3.1 Technisch ontwerp" />
              <xs:enumeration value="3.2 Uitvoering gereed ontwerp" />
              <xs:enumeration value="4.1 Uitvoering" />
              <xs:enumeration value="4.2 Overdracht en oplevering" />
              <xs:enumeration value="4.3 Onderhoudstermijn" />
              <xs:enumeration value="5 Gebruik en Exploitatie" />
            </xs:restriction>
          </ids:value>
        </ids:attribute>
        <ids:attribute cardinality="required" instructions="Eenheden&#xA;voorbeeld: m of mm (gebouwen zijn gebruikelijk in mm en de georeferentie in m) er zijn er dus 2 in IFC files.)">
          <ids:name>
            <ids:simpleValue>UnitsInContext</ids:simpleValue>
          </ids:name>
        </ids:attribute>
        <ids:property dataType="IFCLABEL" uri="https://identifier.buildingsmart.org/uri/buildingsmart/ifc/4.3/prop/ProjectType" cardinality="required">
          <ids:propertySet>
            <ids:simpleValue>Pset_ProjectCommon</ids:simpleValue>
          </ids:propertySet>
          <ids:baseName>
            <ids:simpleValue>ProjectType</ids:simpleValue>
          </ids:baseName>
          <ids:value>
            <xs:restriction base="xs:string">
              <xs:enumeration value="MODIFICATION" />
              <xs:enumeration value="NEWBUILD" />
              <xs:enumeration value="OPERATIONMAINTENANCE" />
              <xs:enumeration value="RENOVATION" />
              <xs:enumeration value="REPAIR" />
            </xs:restriction>
          </ids:value>
        </ids:property>
        <ids:property uri="https://identifier.buildingsmart.org/uri/buildingsmart/ifc/4.3/prop/ProjectInvestmentEstimate" cardinality="optional" instructions="Stichtingskosten: NEN2699 Niveau 1 : A t/m G&#xA;Voorbeeld: 1000000">
          <ids:propertySet>
            <ids:simpleValue>Pset_ProjectCommon</ids:simpleValue>
          </ids:propertySet>
          <ids:baseName>
            <ids:simpleValue>ProjectInvestmentEstimate</ids:simpleValue>
          </ids:baseName>
        </ids:property>
      </ids:requirements>
    </ids:specification>
    <ids:specification ifcVersion="IFC4 IFC4X3_ADD2" name="GeoreferentieProjectedCRS" identifier="GeoreferentieProjectedCRS" description="Een informatiemodel moet de IFCClass IFCPROJECTEDCRS met attribuut VerticalDatum EPSG:7415 (RD+NAP)of EPSG:28992 (RD) én EPSG:5709 (NAP)" instructions="Deze CRS-eis geldt alleen voor Nederlandse projecten waarbij de omvang van het project i.c.m. de kromming van de aarde geen probleem oplevert. Als dit niet geldt dan is het ook mogelijk om eventueel IfcGeographicCRS en/of andere EPSG te gebruiken.">
      <ids:applicability minOccurs="1" maxOccurs="unbounded">
        <ids:entity>
          <ids:name>
            <ids:simpleValue>IFCPROJECTEDCRS</ids:simpleValue>
          </ids:name>
        </ids:entity>
        <ids:attribute>
          <ids:name>
            <ids:simpleValue>Name</ids:simpleValue>
          </ids:name>
          <ids:value>
            <xs:restriction base="xs:string">
              <xs:enumeration value="EPSG:7415" />
              <xs:enumeration value="EPSG:28992" />
            </xs:restriction>
          </ids:value>
        </ids:attribute>
      </ids:applicability>
      <ids:requirements>
        <ids:attribute cardinality="required" instructions="Doel coördinatenstelsel waarin het BIM-model geplaatst wordt. EPSG 7415&#xA;Het attribuut TargetCRS voor Nederlandse indiening heeft als verplichte waarde een IfcProjectedCRS met attribuut VerticalDatum EPSG:7415 (RD+NAP)of EPSG:28992 (RD) én EPSG:5709 (NAP)&#xA;https://www.opengis.net/def/crs/EPSG/0/28992">
          <ids:name>
            <ids:simpleValue>Name</ids:simpleValue>
          </ids:name>
          <ids:value>
            <xs:restriction base="xs:string">
              <xs:enumeration value="EPSG:7415" />
              <xs:enumeration value="EPSG:28992" />
            </xs:restriction>
          </ids:value>
        </ids:attribute>
      </ids:requirements>
    </ids:specification>
    <ids:specification ifcVersion="IFC4 IFC4X3_ADD2" name="GeoreferentieMapConversion" identifier="GeoreferentieMapConversion" description="Een informatiemodel moet de IFCClass IFCMAPCONVERSION bevatten met de attributen SourceCRS, TargetCRS, Easting, Northing, OrthogonalHeight, XAxisAbscissa, XAxisOrdinate en Scale ingevuld." instructions="Deze CRS-eis geldtDeze CRS-eis geldt alleen voor Nederlandse projecten waarbij de omvang van het project i.c.m. de kromming van de aarde geen probleem oplevert. Als dit niet geldt dan is het ook mogelijk om eventueel IfcGeographicCRS en/of andere EPSG te gebruiken.">
      <ids:applicability minOccurs="1" maxOccurs="unbounded">
        <ids:entity>
          <ids:name>
            <ids:simpleValue>IFCMAPCONVERSION</ids:simpleValue>
          </ids:name>
        </ids:entity>
      </ids:applicability>
      <ids:requirements>
        <ids:attribute cardinality="optional" instructions="Het broncoördinatenstelsel van het BIM-model&#xA;Voorbeeld: IfcGeometric-RepresentationContext">
          <ids:name>
            <ids:simpleValue>SourceCRS</ids:simpleValue>
          </ids:name>
        </ids:attribute>
        <ids:attribute cardinality="optional" instructions="Doel coördinatenstelsel waarin het BIM-model geplaatst wordt.&#xA;EPSG 7415&#xA;&#xA;Het attribuut TargetCRS voor Nederlandse indiening heeft als verplichte waarde een IfcProjectedCRS met attribuut VerticalDatum EPSG:7415 (RD+NAP)of EPSG:28992 (RD) én EPSG:5709 (NAP)">
          <ids:name>
            <ids:simpleValue>TargetCRS</ids:simpleValue>
          </ids:name>
          <ids:value>
            <xs:restriction base="xs:string">
              <xs:enumeration value="EPSG:7415" />
              <xs:enumeration value="EPSG:28992" />
            </xs:restriction>
          </ids:value>
        </ids:attribute>
        <ids:attribute cardinality="required" instructions="Verplaatsing in Oostrichting om het BIM-model op de goede plek te krijgen.&#xA;Voorbeeld: 92370.710706">
          <ids:name>
            <ids:simpleValue>Eastings</ids:simpleValue>
          </ids:name>
        </ids:attribute>
        <ids:attribute cardinality="required" instructions="Verplaatsing in Noordrichting om het BIM-model op de goede plek te krijgen.&#xA;Voorbeeld: 437455.379788">
          <ids:name>
            <ids:simpleValue>Northings</ids:simpleValue>
          </ids:name>
        </ids:attribute>
        <ids:attribute cardinality="required" instructions="Verplaatsing in Hoogterichting om het BIM-model op de goede plek te krijgen.&#xA;Voorbeeld: 1.3092">
          <ids:name>
            <ids:simpleValue>OrthogonalHeight</ids:simpleValue>
          </ids:name>
        </ids:attribute>
        <ids:attribute cardinality="required" instructions="Specificeert de waarde langs de oostelijke as van het eindpunt van een vector die de positie van de lokale x-as van het engineering coördinaatreferentiesysteem aangeeft.&#xA;Voorbeeld: 0.8">
          <ids:name>
            <ids:simpleValue>XAxisAbscissa</ids:simpleValue>
          </ids:name>
        </ids:attribute>
        <ids:attribute cardinality="required" instructions="Specificeert de waarde langs de oostelijke as van het eindpunt van een vector die de positie van de lokale x-as van het engineering coördinaatreferentiesysteem aangeeft.&#xA;Voorbeeld: 0.1">
          <ids:name>
            <ids:simpleValue>XAxisOrdinate</ids:simpleValue>
          </ids:name>
        </ids:attribute>
        <ids:attribute cardinality="optional" instructions="Schaal van eenheden in BIM-model t.o.v. eenheden in target CRS&#xA;Voorbeeld: 1/0.001">
          <ids:name>
            <ids:simpleValue>Scale</ids:simpleValue>
          </ids:name>
        </ids:attribute>
      </ids:requirements>
    </ids:specification>
    <ids:specification ifcVersion="IFC4 IFC4X3_ADD2" name="Bouwlaag" instructions="Een model voor de onderwijshuisvesting dient minimaal 1 IFCClass IFCBuildingStorey te hebben met de attributen Name, Objecttype, Longname">
      <ids:applicability minOccurs="1" maxOccurs="unbounded">
        <ids:entity>
          <ids:name>
            <ids:simpleValue>IFCBUILDINGSTOREY</ids:simpleValue>
          </ids:name>
        </ids:entity>
      </ids:applicability>
      <ids:requirements>
        <ids:partOf relation="IFCRELAGGREGATES" cardinality="required">
          <ids:entity>
            <ids:name>
              <ids:simpleValue>IFCBUILDING</ids:simpleValue>
            </ids:name>
          </ids:entity>
        </ids:partOf>
        <ids:attribute cardinality="required" instructions="conform lijst BIM basis ILS - later invullen lex bijvoorbeeld  00 begane grond, 01 eerste verdieping">
          <ids:name>
            <ids:simpleValue>Name</ids:simpleValue>
          </ids:name>
          <ids:value>
            <xs:restriction base="xs:string">
              <xs:enumeration value="-9 kelder" />
              <xs:enumeration value="-8 kelder" />
              <xs:enumeration value="-7 kelder" />
              <xs:enumeration value="-6 kelder" />
              <xs:enumeration value="-5 kelder" />
