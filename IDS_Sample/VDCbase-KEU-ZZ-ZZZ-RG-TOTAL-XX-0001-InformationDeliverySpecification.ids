            <xs:restriction base="xs:string">
              <xs:pattern value="(CEILING|FLOORING|CLADDING|ROOFING|MOLDING|INSULATION|MEMBRANE|SLEEVING|WRAPPING|USERDEFINED|NOTDEFINED)" />
            </xs:restriction>
          </ids:value>
