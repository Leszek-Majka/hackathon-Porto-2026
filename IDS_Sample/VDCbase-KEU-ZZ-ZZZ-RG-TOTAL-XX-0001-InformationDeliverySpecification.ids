        </ids:property>
        <ids:property uri="https://identifier.buildingsmart.org/uri/buildingsmart/ifc/4.3/prop/AssessmentType" cardinality="required" instructions="Category of latest condition assessment report of the asset.">
          <ids:propertySet>
            <ids:simpleValue>Pset_Condition</ids:simpleValue>
          </ids:propertySet>
          <ids:baseName>
            <ids:simpleValue>AssessmentType</ids:simpleValue>
          </ids:baseName>
        </ids:property>
        <ids:property uri="https://identifier.buildingsmart.org/uri/buildingsmart/ifc/4.3/prop/AssessmentMethod" cardinality="required" instructions="External reference to assessment method or application used to perform the assessment.">
          <ids:propertySet>
