            </xs:restriction>
          </ids:value>
        </ids:attribute>
        <ids:attribute cardinality="optional" instructions="Beschrijving van het soort IfcBuildingStorey&#xA;Voorbeeld: entreeverdieping">
          <ids:name>
            <ids:simpleValue>ObjectType</ids:simpleValue>
          </ids:name>
        </ids:attribute>
        <ids:attribute cardinality="optional">
          <ids:name>
            <ids:simpleValue>LongName</ids:simpleValue>
          </ids:name>
        </ids:attribute>
        <ids:property dataType="IFCBOOLEAN" uri="https://identifier.buildingsmart.org/uri/buildingsmart/ifc/4.3/prop/EntranceLevel" cardinality="optional" instructions="optioneel kan er een kenmerk worden meegegeven voor de entree bouwlaag">
          <ids:propertySet>
            <ids:simpleValue>Pset_BuildingStoreyCommon</ids:simpleValue>
          </ids:propertySet>
          <ids:baseName>
            <ids:simpleValue>EntranceLevel</ids:simpleValue>
          </ids:baseName>
        </ids:property>
