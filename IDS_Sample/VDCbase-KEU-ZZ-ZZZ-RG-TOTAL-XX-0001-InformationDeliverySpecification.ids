            <ids:simpleValue>IFCDAMPER</ids:simpleValue>
          </ids:name>
        </ids:entity>
      </ids:applicability>
      <ids:requirements>
        <ids:partOf relation="IFCRELASSIGNSTOGROUP" cardinality="required">
          <ids:entity>
