        <ids:property uri="https://identifier.buildingsmart.org/uri/buildingsmart/ifc/4.3/prop/SafetyDocument" cardinality="optional" instructions="Manufacturer's veiligheidsdocument">
          <ids:propertySet>
            <ids:simpleValue>Pset_ManufacturerTypeInformation</ids:simpleValue>
          </ids:propertySet>
          <ids:baseName>
            <ids:simpleValue>SafetyDocument</ids:simpleValue>
          </ids:baseName>
        </ids:property>
        <ids:property uri="https://identifier.buildingsmart.org/uri/buildingsmart/ifc/4.3/prop/AssessmentCondition" cardinality="optional" instructions="The overall condition of a product based on an assessment of the contributions to the overall condition made by the various criteria considered. The meanings given to the values of assessed condition should be agreed and documented by local agreements. For instance, is overall condition measured on a scale of 1 - 10 or by assigning names such as Good, OK, Poor.">
          <ids:propertySet>
            <ids:simpleValue>Pset_Condition</ids:simpleValue>
          </ids:propertySet>
          <ids:baseName>
            <ids:simpleValue>AssessmentCondition</ids:simpleValue>
          </ids:baseName>
        </ids:property>
        <ids:property dataType="IFCDATE" uri="https://identifier.buildingsmart.org/uri/buildingsmart/ifc/4.3/prop/AssessmentDate" cardinality="optional" instructions="Date on which the overall condition is assessed">
          <ids:propertySet>
