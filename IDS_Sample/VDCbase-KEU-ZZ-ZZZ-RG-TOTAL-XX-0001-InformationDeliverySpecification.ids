    <ids:specification ifcVersion="IFC4 IFC4X3_ADD2" name="Schakelkast" identifier="Electric distribution boards">
      <ids:applicability minOccurs="1" maxOccurs="unbounded">
        <ids:entity>
          <ids:name>
            <ids:simpleValue>IFCELECTRICDISTRIBUTIONBOARD</ids:simpleValue>
          </ids:name>
        </ids:entity>
      </ids:applicability>
      <ids:requirements>
        <ids:partOf relation="IFCRELASSIGNSTOGROUP" cardinality="required">
          <ids:entity>
            <ids:name>
              <ids:simpleValue>IFCSYSTEM</ids:simpleValue>
            </ids:name>
          </ids:entity>
        </ids:partOf>
        <ids:classification cardinality="required">
          <ids:value>
            <xs:restriction base="xs:string">
              <xs:pattern value="[0-9]{2}\.[0-9]{2}.*" />
            </xs:restriction>
          </ids:value>
