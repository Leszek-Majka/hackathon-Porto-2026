    <ids:specification ifcVersion="IFC4 IFC4X3_ADD2" name="Gebruiksfunctie Bruto bepaald" identifier="Oppervlak" instructions="Een Informatiemodel voor onderwijshuisvesting dient minimaal 1 IFCClass IfcSpace of IfcSpatialZone te hebben van het ObjectType Gebruiksfunctie. De attributen Name, Description=Bruto Volume en Objecttype, property GrossArea is verplicht. Object met geometrie is verplicht.&#xA;Een Informatiemodel dient bij een ObjectType Gebruiksfunctie en de Name=Onderwijsfunctie de property Occupancytype in te vullen met de beschikbare SBI-code start met 85..&#xA;">
      <ids:applicability minOccurs="1" maxOccurs="unbounded">
        <ids:attribute>
          <ids:name>
            <ids:simpleValue>ObjectType</ids:simpleValue>
          </ids:name>
          <ids:value>
            <ids:simpleValue>Gebruiksfunctie</ids:simpleValue>
          </ids:value>
        </ids:attribute>
      </ids:applicability>
      <ids:requirements>
        <ids:entity>
          <ids:name>
            <xs:restriction base="xs:string">
              <xs:enumeration value="IFCSPACE" />
              <xs:enumeration value="IFCSPATIALZONE" />
            </xs:restriction>
          </ids:name>
        </ids:entity>
        <ids:attribute cardinality="required" instructions="Gebruiksfunctie volgens enumeratie BBL: https://iplo.nl/thema/bouw/gebruiksfuncties-bouwwerken/&#xA;Woonfunctie, Bijeenkomstfunctie, Celfunctie, Gezondheidszorgfunctie, Industriefunctie, Kantoorfunctie, Logiesfunctie, Onderwijsfunctie, Sportfunctie, Winkelfunctie, Overige Gebruiksfunctie, Bouwwerk Geen Gebouw Zijnde&#xA;subgebruikfuncties">
          <ids:name>
            <ids:simpleValue>Name</ids:simpleValue>
          </ids:name>
          <ids:value>
            <xs:restriction base="xs:string">
              <xs:enumeration value="Onderwijsfunctie" />
              <xs:enumeration value="Woonfunctie" />
              <xs:enumeration value="Bijeenkomstfunctie" />
              <xs:enumeration value="Celfunctie" />
              <xs:enumeration value="Gezondheidszorgfunctie" />
              <xs:enumeration value="Industriefunctie" />
              <xs:enumeration value="Kantoorfunctie" />
              <xs:enumeration value="Logiesfunctie" />
              <xs:enumeration value="Sportfunctie" />
              <xs:enumeration value="Winkelfunctie" />
              <xs:enumeration value="Overige Gebruiksfunctie" />
              <xs:enumeration value="Bouwwerk Geen Gebouw Zijnde" />
            </xs:restriction>
          </ids:value>
        </ids:attribute>
        <ids:attribute cardinality="required" instructions="Bepalingsmethode Bruto Inhoud, Gebruiks Inhoud">
          <ids:name>
            <ids:simpleValue>Description</ids:simpleValue>
          </ids:name>
          <ids:value>
            <xs:restriction base="xs:string">
              <xs:enumeration value="Bruto Inhoud" />
              <xs:enumeration value="Gebruiksinhoud" />
              <xs:enumeration value="Verhuurbare Inhoud" />
            </xs:restriction>
          </ids:value>
        </ids:attribute>
        <ids:attribute cardinality="required">
          <ids:name>
            <ids:simpleValue>ObjectType</ids:simpleValue>
          </ids:name>
          <ids:value>
            <ids:simpleValue>Gebruiksfunctie</ids:simpleValue>
          </ids:value>
        </ids:attribute>
        <ids:property uri="https://identifier.buildingsmart.org/uri/buildingsmart/ifc/4.3/prop/GrossFloorArea" cardinality="required">
          <ids:propertySet>
            <xs:restriction base="xs:string">
              <xs:enumeration value="Qto_SpaceBaseQuantities" />
              <xs:enumeration value="Qto_SpatialZoneBaseQuantities" />
            </xs:restriction>
          </ids:propertySet>
          <ids:baseName>
            <ids:simpleValue>GrossFloorArea</ids:simpleValue>
          </ids:baseName>
        </ids:property>
      </ids:requirements>
    </ids:specification>
    <ids:specification ifcVersion="IFC4 IFC4X3_ADD2" name="Functie-, verblijfs-, bed- of restruimte Netto bepaald" identifier="Ruimte" instructions="Een Informatiemodel voor onderwijshuisvesting dient minimaal 1 IFCClass IfcSpace te hebben van het ObjectType Functie-, Verblijfs-, Bed-, of Restruimte. De attributen Name, Description=Netto Volume en ObjectType zijn verplicht. Object met eigen geometrie is verplicht.">
      <ids:applicability minOccurs="1" maxOccurs="unbounded">
        <ids:attribute>
          <ids:name>
            <ids:simpleValue>ObjectType</ids:simpleValue>
          </ids:name>
          <ids:value>
            <xs:restriction base="xs:string">
              <xs:enumeration value="Functieruimte" />
              <xs:enumeration value="Verblijfsruimte" />
              <xs:enumeration value="Bedruimte" />
              <xs:enumeration value="Restruimte" />
            </xs:restriction>
          </ids:value>
        </ids:attribute>
      </ids:applicability>
      <ids:requirements>
        <ids:entity>
          <ids:name>
            <ids:simpleValue>IFCSPACE</ids:simpleValue>
          </ids:name>
        </ids:entity>
        <ids:attribute cardinality="required" instructions="Bepalingsmethode&#xA; Netto Inhoud">
          <ids:name>
            <ids:simpleValue>Description</ids:simpleValue>
          </ids:name>
          <ids:value>
            <ids:simpleValue>Netto Inhoud</ids:simpleValue>
          </ids:value>
        </ids:attribute>
        <ids:attribute cardinality="required" instructions="Verdere typering van de ruimte conform ruimte ok lijst en handboek basis data POHV&#xA;Voorbeeld: Slaapkamer">
          <ids:name>
            <ids:simpleValue>Name</ids:simpleValue>
          </ids:name>
          <ids:value>
            <xs:restriction base="xs:string">
              <xs:enumeration value="Bergruimte" />
              <xs:enumeration value="Bewegingsruimte (sporten)" />
              <xs:enumeration value="Centraal hart" />
              <xs:enumeration value="EHBO/kolfruimte" />
              <xs:enumeration value="Instructieruimte (leren)" />
              <xs:enumeration value="Kantine" />
              <xs:enumeration value="Kantoorruimte (werken)" />
              <xs:enumeration value="Kleedkamer" />
              <xs:enumeration value="Leerplein" />
              <xs:enumeration value="Ontmoetingsruimte (pauzeren)" />
              <xs:enumeration value="Overige ruimten" />
              <xs:enumeration value="Praktijkruimte (leren)" />
              <xs:enumeration value="Sanitaire ruimte" />
              <xs:enumeration value="Slaapruimte" />
              <xs:enumeration value="Technische ruimte" />
              <xs:enumeration value="Verkeersruimte" />
              <xs:enumeration value="Woonkamer" />
              <xs:enumeration value="Keuken" />
              <xs:enumeration value="Slaapkamer" />
              <xs:enumeration value="Eetkamer" />
              <xs:enumeration value="Kantoorruimte" />
              <xs:enumeration value="Bedrijfsruimte" />
              <xs:enumeration value="Cel" />
              <xs:enumeration value="Bedruimte" />
              <xs:enumeration value="Berging" />
              <xs:enumeration value="Scootmobielruimte" />
              <xs:enumeration value="Bijkeuken" />
              <xs:enumeration value="Kast" />
              <xs:enumeration value="Buitenberging" />
              <xs:enumeration value="Parkeerkelder" />
              <xs:enumeration value="Kelder" />
              <xs:enumeration value="Parkeerplaats" />
              <xs:enumeration value="Rijwielstalling" />
              <xs:enumeration value="Garage" />
              <xs:enumeration value="Verkeersruimte" />
              <xs:enumeration value="Badruimte" />
              <xs:enumeration value="Toiletruimte" />
              <xs:enumeration value="Atrium" />
              <xs:enumeration value="Overloop" />
              <xs:enumeration value="Entree" />
              <xs:enumeration value="Rooksluis" />
              <xs:enumeration value="Galerij" />
              <xs:enumeration value="Trappenhuis" />
              <xs:enumeration value="Gang" />
              <xs:enumeration value="Lift" />
              <xs:enumeration value="Hal" />
              <xs:enumeration value="Badkamer" />
              <xs:enumeration value="Toilet" />
              <xs:enumeration value="WC" />
            </xs:restriction>
          </ids:value>
        </ids:attribute>
        <ids:attribute cardinality="required" instructions="Beschrijving van het soort ruimte (enumeratie BBL-ruimte)&#xA;Voorbeeld: Verblijfsruimte">
          <ids:name>
            <ids:simpleValue>ObjectType</ids:simpleValue>
          </ids:name>
          <ids:value>
            <xs:restriction base="xs:string">
              <xs:enumeration value="Functieruimte" />
              <xs:enumeration value="Verblijfsruimte" />
              <xs:enumeration value="Bedruimte" />
              <xs:enumeration value="Restruimte" />
            </xs:restriction>
          </ids:value>
        </ids:attribute>
        <ids:attribute cardinality="required" instructions="Projectspecifieke ruimtenaam&#xA;Voorbeeld: Master bedroom">
          <ids:name>
            <ids:simpleValue>LongName</ids:simpleValue>
          </ids:name>
        </ids:attribute>
        <ids:property dataType="IFCLABEL" uri="https://identifier.buildingsmart.org/uri/buildingsmart/ifc/4.3/prop/OccupancyType" cardinality="required" instructions="Requirement 13&#xA;Een BIM-Model dient bij een ObjectType Gebruiksfunctie en de Name anders dan Woonfunctie de property Occupancytype in te vullen met de beschikbare SBI-code.&#xA;https://www.kvk.nl/over-het-handelsregister/overzicht-standaard-bedrijfsindeling-sbi-codes-voor-activiteiten/">
          <ids:propertySet>
            <ids:simpleValue>Pset_SpaceOccupancyRequirements</ids:simpleValue>
          </ids:propertySet>
          <ids:baseName>
            <ids:simpleValue>OccupancyType</ids:simpleValue>
