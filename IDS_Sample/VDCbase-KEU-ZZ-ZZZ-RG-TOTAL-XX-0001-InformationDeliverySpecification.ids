          </ids:propertySet>
          <ids:baseName>
            <ids:simpleValue>AssessmentMethod</ids:simpleValue>
          </ids:baseName>
        </ids:property>
        <ids:material cardinality="required" />
      </ids:requirements>
    </ids:specification>
    <ids:specification ifcVersion="IFC4 IFC4X3_ADD2" name="Plafond- Vloer- Dakafwerking" identifier="Plafond- Vloer- Dakafwerking">
      <ids:applicability minOccurs="1" maxOccurs="unbounded">
        <ids:entity>
