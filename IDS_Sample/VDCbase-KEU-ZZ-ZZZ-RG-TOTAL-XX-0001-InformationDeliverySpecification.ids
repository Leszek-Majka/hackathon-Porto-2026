          </ids:baseName>
        </ids:property>
        <ids:property uri="https://identifier.buildingsmart.org/uri/buildingsmart/ifc/4.3/prop/AssessmentCondition" cardinality="required" instructions="The overall condition of a product based on an assessment of the contributions to the overall condition made by the various criteria considered. The meanings given to the values of assessed condition should be agreed and documented by local agreements. For instance, is overall condition measured on a scale of 1 - 10 or by assigning names such as Good, OK, Poor.">
          <ids:propertySet>
            <ids:simpleValue>Pset_Condition</ids:simpleValue>
          </ids:propertySet>
          <ids:baseName>
            <ids:simpleValue>AssessmentCondition</ids:simpleValue>
          </ids:baseName>
        </ids:property>
        <ids:property dataType="IFCDATE" uri="https://identifier.buildingsmart.org/uri/buildingsmart/ifc/4.3/prop/AssessmentDate" cardinality="required" instructions="Date on which the overall condition is assessed">
          <ids:propertySet>
            <ids:simpleValue>Pset_Condition</ids:simpleValue>
          </ids:propertySet>
          <ids:baseName>
            <ids:simpleValue>AssessmentDate</ids:simpleValue>
          </ids:baseName>
          <ids:value>
            <xs:restriction base="xs:date">
              <xs:minExclusive value="2000-01-01" />
            </xs:restriction>
          </ids:value>
        </ids:property>
        <ids:property uri="https://identifier.buildingsmart.org/uri/buildingsmart/ifc/4.3/prop/AssessmentDescription" cardinality="required" instructions="Qualitative description of the condition.">
          <ids:propertySet>
            <ids:simpleValue>Pset_Condition</ids:simpleValue>
          </ids:propertySet>
          <ids:baseName>
