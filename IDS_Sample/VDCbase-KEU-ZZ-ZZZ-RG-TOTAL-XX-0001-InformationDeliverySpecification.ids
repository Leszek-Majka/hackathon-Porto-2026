    <ids:specification ifcVersion="IFC4 IFC4X3_ADD2" name="Bouwlaag" instructions="Een model voor de onderwijshuisvesting dient minimaal 1 IFCClass IFCBuildingStorey te hebben met de attributen Name, Objecttype, Longname">
      <ids:applicability minOccurs="1" maxOccurs="unbounded">
        <ids:entity>
