          </ids:name>
        </ids:attribute>
        <ids:attribute cardinality="required">
          <ids:name>
            <ids:simpleValue>PredefinedType</ids:simpleValue>
          </ids:name>
        </ids:attribute>
        <ids:property dataType="IFCCOUNTMEASURE" cardinality="required">
          <ids:propertySet>
            <ids:simpleValue>Qto_ElectricDistributionBoardBaseQuantities</ids:simpleValue>
          </ids:propertySet>
          <ids:baseName>
            <ids:simpleValue>NumberOfCircuits</ids:simpleValue>
          </ids:baseName>
        </ids:property>
        <ids:property uri="https://identifier.buildingsmart.org/uri/TUe/DOR/0.0.2/prop/CertificationRequirement" cardinality="optional" instructions="Certification requirements refer to the specific criteria or standards that need to be met in order to obtain certification for certain products, processes, or components within the context of circular economy practices. Not all circular potentials may require certification, but certification can be necessary for certain reusable structural parts or components. A certificate serves as a validation or endorsement that the product or component meets specific - or minimum - standards or specifications related to safety, quality, environmental impact, or other relevant criteria that makes it eligible to be re-introduced to the market.">
          <ids:propertySet>
            <ids:simpleValue>CircularRequirement</ids:simpleValue>
          </ids:propertySet>
          <ids:baseName>
            <ids:simpleValue>CertificationRequirement</ids:simpleValue>
          </ids:baseName>
        </ids:property>
        <ids:property uri="https://identifier.buildingsmart.org/uri/TUe/DOR/0.0.2/prop/ConnectionType" cardinality="optional" instructions="A superclass that allows to describe the type of the connections. Different connection types faciliate different circular and End-of-Life possibilities, including: (1) Deconstruction, i.e., a building is taken apart into products; (2) Demounting, i.e., a product is taken out of a building; (3) Disassembling, i.e., a product is separated into components or sub-parts; (4) Dismantling, i.e., a product is separated into individual materials.">
          <ids:propertySet>
            <ids:simpleValue>CircularRequirement</ids:simpleValue>
          </ids:propertySet>
          <ids:baseName>
            <ids:simpleValue>ConnectionType</ids:simpleValue>
          </ids:baseName>
          <ids:value>
            <xs:restriction base="xs:string">
              <xs:enumeration value="DirectConnection" />
              <xs:enumeration value="IndirectConnection" />
              <xs:enumeration value="MechanicalConnection" />
              <xs:enumeration value="ChemicalConnection" />
              <xs:enumeration value="ReversibleConnection" />
              <xs:enumeration value="IrreversibleConnection" />
              <xs:enumeration value="IntermediaryConnection" />
              <xs:enumeration value="GravitationalConnection" />
            </xs:restriction>
          </ids:value>
        </ids:property>
        <ids:property uri="https://identifier.buildingsmart.org/uri/TUe/DOR/0.0.2/prop/CircularPotential" cardinality="optional" instructions="Certification requirements refer to the specific criteria or standards that need to be met in order to obtain certification for certain products, processes, or components within the context of circular economy practices. Not all circular potentials may require certification, but certification can be necessary for certain reusable structural parts or components. A certificate serves as a validation or endorsement that the product or component meets specific - or minimum - standards or specifications related to safety, quality, environmental impact, or other relevant criteria that makes it eligible to be re-introduced to the market.">
          <ids:propertySet>
            <ids:simpleValue>CircularRequirement</ids:simpleValue>
          </ids:propertySet>
          <ids:baseName>
            <ids:simpleValue>CircularPotential</ids:simpleValue>
          </ids:baseName>
          <ids:value>
            <xs:restriction base="xs:string">
              <xs:enumeration value="ReusePotential" />
              <xs:enumeration value="RemanufacturingPotential" />
              <xs:enumeration value="RecyclingPotential" />
              <xs:enumeration value="RepurposingPotential" />
              <xs:enumeration value="DiscardPotential" />
            </xs:restriction>
          </ids:value>
        </ids:property>
        <ids:property dataType="IFCDATETIME" uri="https://identifier.buildingsmart.org/uri/TUe/DOR/0.0.2/prop/DecommissioningDate" cardinality="optional" instructions="The date when the building is scheduled or planned to be decommissioned.">
          <ids:propertySet>
            <ids:simpleValue>CircularRequirement</ids:simpleValue>
