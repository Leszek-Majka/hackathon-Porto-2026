              <xs:enumeration value="36 zesendertigste verdieping" />
              <xs:enumeration value="37 zevenendertigste verdieping" />
              <xs:enumeration value="38 achtendertigste verdieping" />
              <xs:enumeration value="39 negendertigste verdieping" />
              <xs:enumeration value="40 veertigste verdieping" />
